# Copy to functions/.env (auto-loaded by firebase-functions v2).
# For PRODUCTION prefer: firebase functions:secrets:set REPLICATE_API_TOKEN

# One-time secret used by bootstrapAdmin() to grant yourself the first admin claim.
BOOTSTRAP_SECRET=change-me-to-a-long-random-string

# Admins by Firebase UID (comma-separated). Anyone in this list becomes an admin
# automatically on their next login (syncAdminClaim). Find UIDs in the Firebase
# console: Authentication -> Users.
ADMIN_UIDS=

# --- Plans & credit economics (COGS is ~$0.04 per un-crop) ---
# Free un-crops per day (per account AND per device, to stop trial farming).
FREE_DAILY=3
# Free resize exports per day (resize is local/no AI cost, but metered the same
# way: a few free/day, then paid users spend 1 credit per export).
RESIZE_FREE_DAILY=3
# Monthly credits for the paid tiers (1 credit = 1 un-crop). Sized for healthy
# margin even at 100% utilisation after the store cut (COGS ~$0.04/credit):
#   Pro    $9.99/mo or $99.99/yr   -> 100 credits ($4.00 max COGS)
#   Studio $29.99/mo or $299.99/yr -> 300 credits ($12.00 max COGS)
PRO_CREDITS=100
STUDIO_CREDITS=300

# RevenueCat SECRET (v1) API key — lets syncSubscription + the webhook verify
# entitlements server-side so a plan can't be faked from the client. Leave blank
# in dev (it then trusts the client's reported plan). RevenueCat: Project
# settings -> API keys -> Secret key.
REVENUECAT_SECRET_KEY=

# Shared secret for the RevenueCat webhook. Set this to any long random string,
# then paste the SAME value as the "Authorization" header in RevenueCat's webhook
# config (Integrations -> Webhooks). Leave blank to disable auth (not recommended).
REVENUECAT_WEBHOOK_AUTH=

# Un-crop provider: "ideogram" (default, V3 Reframe Turbo) or "replicate" (bria).
AI_PROVIDER=ideogram

# Ideogram V3 Reframe (recommended for un-crop). Get a key at https://ideogram.ai
IDEOGRAM_API_KEY=
IDEOGRAM_RENDERING_SPEED=TURBO

# Replicate (used by aiAnimate, and aiUncrop only when AI_PROVIDER=replicate).
REPLICATE_API_TOKEN=

# --- Uncrop (outpaint) model ---
# bria/expand-image extends a single image to a new aspect ratio (no mask).
REPLICATE_UNCROP_MODEL=bria/expand-image
# Default target ratio for un-crop, and the model's input field names.
# Verify the field names on https://replicate.com/bria/expand-image/api and adjust.
REPLICATE_UNCROP_ASPECT=16:9
REPLICATE_UNCROP_IMAGE_FIELD=image_url
REPLICATE_UNCROP_RATIO_FIELD=aspect_ratio

# --- Animate (LivePortrait) model ---
# LivePortrait needs a SOURCE photo + a DRIVING VIDEO (the motion to copy).
REPLICATE_ANIMATE_MODEL=mbukerepo/live-portrait
# A short (3-6s) clip of subtle face/head motion, hosted at a public URL.
# Upload one to Firebase Storage (or any CDN) and paste its download URL here.
REPLICATE_DRIVING_VIDEO_URL=
# Input field names as shown on the model's API tab (defaults below are common).
REPLICATE_ANIMATE_IMAGE_FIELD=image
REPLICATE_ANIMATE_VIDEO_FIELD=driving_video
