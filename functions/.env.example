# Copy to functions/.env (auto-loaded by firebase-functions v2).
# For PRODUCTION prefer: firebase functions:secrets:set REPLICATE_API_TOKEN

# One-time secret used by bootstrapAdmin() to grant yourself the first admin claim.
BOOTSTRAP_SECRET=change-me-to-a-long-random-string

# Cloud AI inference provider (default: Replicate). Used by aiUncrop / aiAnimate.
AI_PROVIDER=replicate
REPLICATE_API_TOKEN=

# --- Uncrop (outpaint) model ---
REPLICATE_UNCROP_MODEL=stability-ai/stable-diffusion-inpainting

# --- Animate (LivePortrait) model ---
# LivePortrait needs a SOURCE photo + a DRIVING VIDEO (the motion to copy).
REPLICATE_ANIMATE_MODEL=mbukerepo/live-portrait
# A short (3-6s) clip of subtle face/head motion, hosted at a public URL.
# Upload one to Firebase Storage (or any CDN) and paste its download URL here.
REPLICATE_DRIVING_VIDEO_URL=
# Input field names as shown on the model's API tab (defaults below are common).
REPLICATE_ANIMATE_IMAGE_FIELD=image
REPLICATE_ANIMATE_VIDEO_FIELD=driving_video
