# Copy to app/.env. EXPO_PUBLIC_* vars are inlined into the JS bundle.
# Firebase web API keys are NOT secrets — security comes from Auth + rules.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google Sign-In (OAuth client IDs from Google Cloud / Firebase Auth console).
# iOS client id is required for native Google sign-in in a dev/standalone build.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Region your Cloud Functions are deployed to (default us-central1).
EXPO_PUBLIC_FUNCTIONS_REGION=us-central1
